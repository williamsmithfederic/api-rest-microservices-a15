    <connection id="180ff433-6971-4712-9d61-cb9c5311416e">
      <console name="Connection sql" type="STANDARD" schema="main" session="Main"><![CDATA[select * from incidents;

select * from absences;

select * from service_fait;

select * from service_fait_detail;

select * from  client;

select * from employe;

select 
    sf.id as intervention_id,
    sf.commentaire,
    s.nom as service_nom,
    s.prix
from service_fait sf
join service_fait_detail sfd on sf.id = sfd.service_fait_id
join service s on s.id = sfd.service_id
order by sf.id desc;

select name
from sqlite_master
where type='table';

--  pour ajouter la colonne 
alter table incidents add column date_cloture text;

pragma table_info(incidents);


-- ================================
-- Script pour creer table Service_fait Mobile 
-- TABLE DES SERVICES DISPONIBLES
-- ================================
create table if not exists service (
    id integer primary key autoincrement,
    nom text not null,
    prix real not null
);

-- ================================
-- TABLE INTERVENTION (service_fait)
-- ================================
create table if not exists service_fait (
    id integer primary key autoincrement,
    employe_id integer not null,
    client_id integer not null,
    commentaire text,
    total real,
    date_creation datetime default current_timestamp
);

-- =====================================
-- TABLE DETAIL (relation MANY TO MANY)
-- =====================================
create table if not exists service_fait_detail (
    id integer primary key autoincrement,
    service_fait_id integer not null,
    service_id integer not null,
    prix real not null,
    foreign key(service_fait_id) references service_fait(id),
    foreign key(service_id) references service(id)
);

-- ================================
-- INSERT SERVICES DE BASE
-- ================================
insert into service (nom, prix) values
('Nettoyage', 50),
('Réparation', 75),
('Installation', 100),
('Diagnostic', 40),
('Maintenance préventive', 60),
('Urgence 24/7', 150);

-- ================================
-- Creer table client 
-- ================================
create table if not exists client (
    id integer primary key autoincrement,
    nom text not null
);

insert into client (nom) values
('Mohamed Ali'),
('Martin Marie'),
('Hafed Pierre'),
('Amine Luc'),
('Youcef Marc');


UPDATE service_fait
SET date = datetime('now')
WHERE date IS NULL;

-- creat table employe 
CREATE TABLE IF NOT EXISTS employe (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT UNIQUE,
    password TEXT
);

INSERT INTO employe (username, password)
VALUES ('admin', '1234');

INSERT INTO employe (username, password)
VALUES ('user', '1234');

--requête SQL propre pour afficher :
-- total global par client

SELECT 
    sf.id,
    c.nom AS client,
    sf.commentaire,
    sf.total,
    sf.date
FROM service_fait sf
LEFT JOIN client c ON sf.client_id = c.id
ORDER BY sf.id DESC;

-- affiche tout les intervention avec id_client et id_employe

SELECT * FROM service_fait ORDER BY id DESC;]]></console>
